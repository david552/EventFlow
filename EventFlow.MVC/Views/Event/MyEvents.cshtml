@model List<EventFlow.Application.Events.Responses.EventResponseModel>
@{
    ViewData["Title"] = "My Events";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="bi bi-calendar2-event"></i> My Created Events</h2>
        <a asp-controller="Event" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Event
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light border text-center py-5 shadow-sm">
            <i class="bi bi-calendar-x fs-1 text-muted"></i>
            <p class="mt-3 fs-5">You have not created any events yet.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-primary border-top border-3">
                        <div class="card-body">
                            <div class="mb-2">
                                @if (item.EndTime < DateTime.Now)
                                {
                                    <span class="badge bg-secondary"><i class="bi bi-calendar-x"></i> Ended</span>
                                }
                                else if (item.IsActive)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Pending</span>
                                }
                            </div>

                            <h5 class="card-title fw-bold">@item.Title</h5>
                            <p class="card-text text-muted small"><i class="bi bi-clock"></i> @item.StartTime.ToString("dd MMM yyyy HH:mm")</p>

                            <div class="d-flex justify-content-between align-items-center mt-4">
                                <span class="badge bg-secondary">Remaining: @item.AvailableTickets</span>

                                @if (item.EndTime < DateTime.Now)
                                {
                                    <button class="btn btn-outline-secondary btn-sm" disabled title="Cannot edit an expired event">
                                        <i class="bi bi-lock"></i> Edit
                                    </button>
                                }
                                else
                                {
                                    <a asp-controller="Event" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>