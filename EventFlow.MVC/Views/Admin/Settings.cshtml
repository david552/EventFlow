@model EventFlow.MVC.Models.SettingsViewModel
@{
    ViewData["Title"] = "System Settings";
}

<h2>Global Settings</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Settings" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <table class="table table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Parameter</th>
                        <th>Value</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Settings.Count; i++)
                    {
                        <tr>
                            <td>
                                @Model.Settings[i].Key
                                <input type="hidden" asp-for="Settings[i].Id" />
                                <input type="hidden" asp-for="Settings[i].Key" />
                            </td>
                            <td>
                                <input asp-for="Settings[i].Value" class="form-control" type="number" />
                                <span asp-validation-for="Settings[i].Value" class="text-danger"></span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <button type="submit" class="btn btn-primary">Save Settings</button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}